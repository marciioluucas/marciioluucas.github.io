---
import { vehicles, DEFAULT_SLUG } from '../lib/vehicles';
import History from './History.tsx';

interface Props { initialSlug?: string }
const { initialSlug = DEFAULT_SLUG } = Astro.props;
const v = vehicles[initialSlug] ?? vehicles[DEFAULT_SLUG];

const fmt = (n: number) => String(n).replace('.', ',');

const inputClass = "mt-1 w-full rounded-md border border-border bg-surface p-3";

// Agrupar veiculos por marca pra cascading selects
const allVehicles = Object.values(vehicles);
const marcas = [...new Set(allVehicles.map((x) => x.marca))].sort();
---
<form id="combustivel-form" class="container-app py-4 space-y-6"
      data-tanque={v.tanque}>
  <div class="space-y-3">
    <label class="block text-base font-medium" for="marca-select">Qual é o seu carro?</label>

    <button type="button" id="meu-carro-btn"
            class="hidden w-full rounded-md border-2 border-accent bg-accent/10 p-3 text-left text-base">
      ⭐ Usar meu carro: <span id="meu-carro-btn-text"></span>
    </button>

    <div class="grid gap-3 sm:grid-cols-3">
      <div>
        <span class="block text-sm text-muted">Marca</span>
        <select id="marca-select" class="mt-1 w-full rounded-md border border-border bg-surface p-4 text-base">
          {marcas.map((m) => (
            <option value={m} selected={m === v.marca}>{m}</option>
          ))}
        </select>
      </div>
      <div>
        <span class="block text-sm text-muted">Modelo</span>
        <select id="modelo-select" class="mt-1 w-full rounded-md border border-border bg-surface p-4 text-base"></select>
      </div>
      <div>
        <span class="block text-sm text-muted">Versão / Ano</span>
        <select id="versao-select" class="mt-1 w-full rounded-md border border-border bg-surface p-4 text-base"></select>
      </div>
    </div>
    <input type="hidden" id="vehicle-select" value={v.slug} />
  </div>

  <details id="meu-carro-details" class="rounded-md border border-border bg-surface">
    <summary class="cursor-pointer select-none p-3 text-sm font-medium">
      🚗 <span id="meu-carro-summary-text">Cadastrar meu carro</span>
    </summary>
    <div class="space-y-3 p-3 pt-0">
      <p class="text-xs text-muted">Salvo apenas no seu navegador. Aparece como primeira opção no seletor.</p>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm text-muted">Marca</span>
          <input id="mc-marca" type="text" class={inputClass} placeholder="Honda" />
        </label>
        <label class="block">
          <span class="text-sm text-muted">Modelo</span>
          <input id="mc-modelo" type="text" class={inputClass} placeholder="Civic EXL" />
        </label>
        <label class="block">
          <span class="text-sm text-muted">Ano</span>
          <input id="mc-ano" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="4" class={inputClass} placeholder="2018" />
        </label>
        <label class="block">
          <span class="text-sm text-muted">Tanque (litros)</span>
          <input id="mc-tanque" type="text" inputmode="decimal" data-decimal class={inputClass} placeholder="56" />
        </label>
      </div>
      <p class="text-sm font-semibold mt-2">Autonomia em cidade (km/l)</p>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm text-muted">Gasolina</span>
          <input id="mc-ag-cidade" type="text" inputmode="decimal" data-decimal class={inputClass} />
        </label>
        <label class="block">
          <span class="text-sm text-muted">Etanol</span>
          <input id="mc-ae-cidade" type="text" inputmode="decimal" data-decimal class={inputClass} />
        </label>
      </div>
      <p class="text-sm font-semibold mt-2">Autonomia em estrada (km/l)</p>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm text-muted">Gasolina</span>
          <input id="mc-ag-estrada" type="text" inputmode="decimal" data-decimal class={inputClass} />
        </label>
        <label class="block">
          <span class="text-sm text-muted">Etanol</span>
          <input id="mc-ae-estrada" type="text" inputmode="decimal" data-decimal class={inputClass} />
        </label>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row">
        <button type="button" id="mc-salvar"
                class="flex-1 rounded-md bg-accent py-3 text-sm font-bold text-bg active:scale-[0.99]">
          Salvar meu carro
        </button>
        <button type="button" id="mc-remover"
                class="rounded-md border border-danger px-4 py-3 text-sm text-danger hidden">
          Remover
        </button>
      </div>
    </div>
  </details>

  <fieldset class="space-y-4">
    <legend class="text-lg font-bold">Quanto está custando hoje?</legend>
    <div class="grid gap-3 sm:grid-cols-2">
      <label class="block">
        <span class="text-base">Gasolina <span class="text-muted">(R$ por litro)</span></span>
        <input id="preco-g" type="text" inputmode="decimal" data-decimal
               value="4,90" class="mt-1 w-full rounded-md border border-border bg-surface p-4 text-lg" />
      </label>
      <label class="block">
        <span class="text-base">Etanol <span class="text-muted">(R$ por litro)</span></span>
        <input id="preco-e" type="text" inputmode="decimal" data-decimal
               value="3,79" class="mt-1 w-full rounded-md border border-border bg-surface p-4 text-lg" />
      </label>
    </div>
  </fieldset>

  <details class="rounded-md border border-border bg-surface">
    <summary class="cursor-pointer select-none p-4 text-base font-medium">
      ⚙️ Ajustar consumo do carro <span class="text-muted text-sm">(opcional)</span>
    </summary>
    <div class="space-y-4 p-4 pt-0">
      <p class="text-sm text-muted">Quantos quilômetros seu carro faz com 1 litro?</p>
      <fieldset class="space-y-3">
        <legend class="text-sm font-semibold">Na cidade</legend>
        <div class="grid gap-3 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm text-muted">Gasolina (km/l)</span>
            <input id="ag-cidade" type="text" inputmode="decimal" data-decimal
                   value={fmt(v.autonomia.gasolina.cidade)} class={inputClass} />
          </label>
          <label class="block">
            <span class="text-sm text-muted">Etanol (km/l)</span>
            <input id="ae-cidade" type="text" inputmode="decimal" data-decimal
                   value={fmt(v.autonomia.etanol.cidade)} class={inputClass} />
          </label>
        </div>
      </fieldset>
      <fieldset class="space-y-3">
        <legend class="text-sm font-semibold">Na estrada</legend>
        <div class="grid gap-3 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm text-muted">Gasolina (km/l)</span>
            <input id="ag-estrada" type="text" inputmode="decimal" data-decimal
                   value={fmt(v.autonomia.gasolina.estrada)} class={inputClass} />
          </label>
          <label class="block">
            <span class="text-sm text-muted">Etanol (km/l)</span>
            <input id="ae-estrada" type="text" inputmode="decimal" data-decimal
                   value={fmt(v.autonomia.etanol.estrada)} class={inputClass} />
          </label>
        </div>
      </fieldset>
    </div>
  </details>

  <button type="submit"
          class="w-full rounded-lg bg-primary py-5 text-xl font-bold text-bg shadow-lg active:scale-[0.99]">
    Descobrir agora
  </button>
</form>

<div id="resultado" aria-live="polite"></div>

<div class="container-app">
  <History client:idle />
</div>

<script>
  import { economiaPorTanque } from '../lib/calc';
  import { storage, type StoredVehicle } from '../lib/storage';
  import { vehicles, DEFAULT_SLUG } from '../lib/vehicles';
  import { decodeShare } from '../lib/share';

  const USER_SLUG = '__user__';

  const form = document.getElementById('combustivel-form') as HTMLFormElement;
  const select = document.getElementById('vehicle-select') as HTMLSelectElement;
  const resultadoEl = document.getElementById('resultado')!;

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  // ---- decimal mask: aceita digito e virgula, converte ponto em virgula ----
  function sanitizeDecimal(raw: string): string {
    let v = raw.replace(/\./g, ',');
    v = v.replace(/[^\d,]/g, '');
    const i = v.indexOf(',');
    if (i !== -1) v = v.slice(0, i + 1) + v.slice(i + 1).replace(/,/g, '');
    return v;
  }
  function toNumber(raw: string): number {
    return parseFloat(raw.replace(',', '.')) || 0;
  }
  function fmtDec(n: number): string {
    return String(n).replace('.', ',');
  }
  document.querySelectorAll<HTMLInputElement>('input[data-decimal]').forEach((el) => {
    el.addEventListener('input', () => {
      const start = el.selectionStart;
      const before = el.value;
      const after = sanitizeDecimal(before);
      if (before !== after) {
        el.value = after;
        if (start !== null) {
          const delta = after.length - before.length;
          el.setSelectionRange(start + delta, start + delta);
        }
      }
    });
    el.addEventListener('blur', () => {
      el.value = el.value.replace(/,$/, '');
    });
  });

  // ---- cascading select: marca -> modelo -> versao ----
  const marcaSelect = document.getElementById('marca-select') as HTMLSelectElement;
  const modeloSelect = document.getElementById('modelo-select') as HTMLSelectElement;
  const versaoSelect = document.getElementById('versao-select') as HTMLSelectElement;
  const meuCarroBtn = document.getElementById('meu-carro-btn') as HTMLButtonElement;
  const meuCarroBtnText = document.getElementById('meu-carro-btn-text')!;

  function modelosByMarca(marca: string): string[] {
    const set = new Set<string>();
    for (const v of Object.values(vehicles)) {
      if (v.marca === marca) set.add(v.modelo);
    }
    return [...set].sort();
  }
  function versoesByMarcaModelo(marca: string, modelo: string) {
    return Object.values(vehicles)
      .filter((v) => v.marca === marca && v.modelo === modelo)
      .sort((a, b) => b.ano - a.ano);
  }
  function fillModelos(marca: string, preferModelo?: string) {
    const items = modelosByMarca(marca);
    modeloSelect.innerHTML = items
      .map((m) => `<option value="${m}"${m === preferModelo ? ' selected' : ''}>${m}</option>`)
      .join('');
    fillVersoes(marca, modeloSelect.value);
  }
  function fillVersoes(marca: string, modelo: string, preferSlug?: string) {
    const items = versoesByMarcaModelo(marca, modelo);
    versaoSelect.innerHTML = items
      .map((v) => `<option value="${v.slug}"${v.slug === preferSlug ? ' selected' : ''}>${v.ano}</option>`)
      .join('');
    select.value = versaoSelect.value;
    applyVehicle(versaoSelect.value);
  }
  function syncCascadeFromSlug(slug: string) {
    const v = vehicles[slug];
    if (!v) return;
    marcaSelect.value = v.marca;
    fillModelos(v.marca, v.modelo);
    modeloSelect.value = v.modelo;
    fillVersoes(v.marca, v.modelo, v.slug);
  }
  marcaSelect.addEventListener('change', () => fillModelos(marcaSelect.value));
  modeloSelect.addEventListener('change', () => fillVersoes(marcaSelect.value, modeloSelect.value));
  versaoSelect.addEventListener('change', () => {
    select.value = versaoSelect.value;
    applyVehicle(versaoSelect.value);
  });

  // ---- meu carro: botao topo + cadastro / edicao / remocao ----
  const detailsEl = document.getElementById('meu-carro-details') as HTMLDetailsElement;
  const summaryText = document.getElementById('meu-carro-summary-text')!;
  const removerBtn = document.getElementById('mc-remover')!;
  const salvarBtn = document.getElementById('mc-salvar')!;

  function refreshUserVehicleOption() {
    const uv = storage.getUserVehicle();
    if (uv) {
      meuCarroBtnText.textContent = `${uv.marca} ${uv.modelo} ${uv.ano}`;
      meuCarroBtn.classList.remove('hidden');
      summaryText.textContent = `Meu carro: ${uv.marca} ${uv.modelo} ${uv.ano}`;
      (removerBtn as HTMLElement).classList.remove('hidden');
      $('mc-marca').value = uv.marca;
      $('mc-modelo').value = uv.modelo;
      $('mc-ano').value = String(uv.ano);
      $('mc-tanque').value = fmtDec(uv.tanque);
      $('mc-ag-cidade').value = fmtDec(uv.autonomia.gasolina.cidade);
      $('mc-ae-cidade').value = fmtDec(uv.autonomia.etanol.cidade);
      $('mc-ag-estrada').value = fmtDec(uv.autonomia.gasolina.estrada);
      $('mc-ae-estrada').value = fmtDec(uv.autonomia.etanol.estrada);
    } else {
      meuCarroBtn.classList.add('hidden');
      summaryText.textContent = 'Cadastrar meu carro';
      (removerBtn as HTMLElement).classList.add('hidden');
    }
  }

  meuCarroBtn.addEventListener('click', () => {
    select.value = USER_SLUG;
    applyVehicle(USER_SLUG);
    meuCarroBtn.classList.add('ring-2', 'ring-accent');
    setTimeout(() => meuCarroBtn.classList.remove('ring-2', 'ring-accent'), 800);
  });

  function applyUserVehicle(uv: StoredVehicle) {
    $('ag-cidade').value = fmtDec(uv.autonomia.gasolina.cidade);
    $('ae-cidade').value = fmtDec(uv.autonomia.etanol.cidade);
    $('ag-estrada').value = fmtDec(uv.autonomia.gasolina.estrada);
    $('ae-estrada').value = fmtDec(uv.autonomia.etanol.estrada);
    form.dataset.tanque = String(uv.tanque);
  }

  function applyVehicle(slug: string) {
    if (slug === USER_SLUG) {
      const uv = storage.getUserVehicle();
      if (uv) applyUserVehicle(uv);
      return;
    }
    const v = vehicles[slug];
    if (!v) return;
    $('ag-cidade').value = fmtDec(v.autonomia.gasolina.cidade);
    $('ae-cidade').value = fmtDec(v.autonomia.etanol.cidade);
    $('ag-estrada').value = fmtDec(v.autonomia.gasolina.estrada);
    $('ae-estrada').value = fmtDec(v.autonomia.etanol.estrada);
    form.dataset.tanque = String(v.tanque);
  }

  salvarBtn.addEventListener('click', () => {
    const marca = $('mc-marca').value.trim();
    const modelo = $('mc-modelo').value.trim();
    const ano = parseInt($('mc-ano').value, 10);
    const tanque = toNumber($('mc-tanque').value);
    if (!marca || !modelo || !ano || !tanque) {
      alert('Preencha marca, modelo, ano e tanque.');
      return;
    }
    const uv: StoredVehicle = {
      slug: USER_SLUG,
      marca, modelo, ano, tanque,
      autonomia: {
        gasolina: {
          cidade: toNumber($('mc-ag-cidade').value),
          estrada: toNumber($('mc-ag-estrada').value),
        },
        etanol: {
          cidade: toNumber($('mc-ae-cidade').value),
          estrada: toNumber($('mc-ae-estrada').value),
        },
      },
    };
    storage.setUserVehicle(uv);
    refreshUserVehicleOption();
    select.value = USER_SLUG;
    applyVehicle(USER_SLUG);
    detailsEl.open = false;
  });

  removerBtn.addEventListener('click', () => {
    if (!confirm('Remover seu carro cadastrado?')) return;
    storage.clearUserVehicle();
    if (select.value === USER_SLUG) select.value = DEFAULT_SLUG;
    refreshUserVehicleOption();
    applyVehicle(select.value);
  });

  // init
  refreshUserVehicleOption();

  // cascading inicial baseada no slug atual
  syncCascadeFromSlug(select.value);

  const params = decodeShare(window.location.search);
  if (params.v && vehicles[params.v]) {
    select.value = params.v;
    syncCascadeFromSlug(params.v);
  } else if (params.v === USER_SLUG && storage.getUserVehicle()) {
    select.value = USER_SLUG;
    applyVehicle(USER_SLUG);
  } else if (storage.getUserVehicle()) {
    select.value = USER_SLUG;
    applyVehicle(USER_SLUG);
  }
  if (params.g) $('preco-g').value = fmtDec(params.g);
  if (params.e) $('preco-e').value = fmtDec(params.e);
  if (!params.g && !params.e) {
    const last = storage.getLastPrices();
    if (last.gasolina) $('preco-g').value = fmtDec(last.gasolina);
    if (last.etanol) $('preco-e').value = fmtDec(last.etanol);
  }

  select.addEventListener('change', () => applyVehicle(select.value));

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const tanque = Number(form.dataset.tanque ?? 50);
    const precoG = toNumber($('preco-g').value);
    const precoE = toNumber($('preco-e').value);
    const cidade = economiaPorTanque({
      precoGasolina: precoG, autonomiaGasolina: toNumber($('ag-cidade').value),
      precoEtanol: precoE, autonomiaEtanol: toNumber($('ae-cidade').value),
      tanque,
    });
    const estrada = economiaPorTanque({
      precoGasolina: precoG, autonomiaGasolina: toNumber($('ag-estrada').value),
      precoEtanol: precoE, autonomiaEtanol: toNumber($('ae-estrada').value),
      tanque,
    });
    storage.setLastPrices({ gasolina: precoG, etanol: precoE });
    storage.pushHistory({
      ts: Date.now(), vehicleSlug: select.value,
      prices: { gasolina: precoG, etanol: precoE },
      vencedorCidade: cidade.vencedor, vencedorEstrada: estrada.vencedor,
    });

    const fmtBR = (n: number) => n.toFixed(2).replace('.', ',');
    // Resposta principal: usa o cenario "cidade" como referencia (uso mais comum)
    const venceuCidade = cidade.vencedor;
    const venceuEstrada = estrada.vencedor;
    const mesmaResposta = venceuCidade === venceuEstrada;
    const economiaPrincipal = mesmaResposta
      ? Math.max(cidade.economiaRs, estrada.economiaRs)
      : cidade.economiaRs;
    const combNome = (c: 'gasolina' | 'etanol') => c === 'gasolina' ? 'GASOLINA' : 'ETANOL';
    const combCor = (c: 'gasolina' | 'etanol') => c === 'gasolina' ? 'text-primary' : 'text-accent';
    const respostaCor = mesmaResposta
      ? (venceuCidade === 'gasolina' ? 'border-primary bg-primary/10' : 'border-accent bg-accent/10')
      : 'border-border bg-surface';

    let respostaHtml: string;
    if (mesmaResposta) {
      respostaHtml = `
        <div class="text-center py-4">
          <p class="text-base text-muted">A resposta é</p>
          <p class="mt-2 text-5xl font-extrabold ${combCor(venceuCidade)}">${combNome(venceuCidade)}</p>
          ${economiaPrincipal > 0
            ? `<p class="mt-3 text-lg">Você economiza <strong class="text-accent">R$ ${fmtBR(economiaPrincipal)}</strong> por tanque</p>`
            : ''}
        </div>
      `;
    } else {
      respostaHtml = `
        <div class="text-center py-4">
          <p class="text-base text-muted">Depende de onde você dirige</p>
          <div class="mt-3 grid gap-3 sm:grid-cols-2 text-left">
            <div class="rounded-md bg-bg/40 p-3">
              <p class="text-sm text-muted">Na cidade</p>
              <p class="text-2xl font-bold ${combCor(venceuCidade)}">${combNome(venceuCidade)}</p>
            </div>
            <div class="rounded-md bg-bg/40 p-3">
              <p class="text-sm text-muted">Na estrada</p>
              <p class="text-2xl font-bold ${combCor(venceuEstrada)}">${combNome(venceuEstrada)}</p>
            </div>
          </div>
        </div>
      `;
    }

    const detalheCard = (titulo: string, c: typeof cidade) => `
      <section class="rounded-lg bg-surface p-4">
        <h3 class="text-base font-semibold">${titulo}</h3>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          <article class="${c.vencedor === 'gasolina' ? 'bg-primary/10 border border-primary/30' : 'bg-bg/40'} rounded-md p-3">
            <p class="text-xs uppercase tracking-wide text-muted">Gasolina ${c.vencedor === 'gasolina' ? '★' : ''}</p>
            <p class="mt-1 text-xl font-bold text-primary">R$ ${fmtBR(c.custoGasolinaKm)}<span class="text-xs text-muted">/km</span></p>
            <p class="mt-1 text-xs text-muted">Tanque: ${c.autonomiaTanqueGasolina.toFixed(0)} km</p>
          </article>
          <article class="${c.vencedor === 'etanol' ? 'bg-accent/10 border border-accent/30' : 'bg-bg/40'} rounded-md p-3">
            <p class="text-xs uppercase tracking-wide text-muted">Etanol ${c.vencedor === 'etanol' ? '★' : ''}</p>
            <p class="mt-1 text-xl font-bold text-accent">R$ ${fmtBR(c.custoEtanolKm)}<span class="text-xs text-muted">/km</span></p>
            <p class="mt-1 text-xs text-muted">Tanque: ${c.autonomiaTanqueEtanol.toFixed(0)} km</p>
          </article>
        </div>
      </section>
    `;
    resultadoEl.innerHTML = `
      <div class="container-app">
        <div class="mt-6 rounded-xl border-2 p-4 ${respostaCor}">
          ${respostaHtml}
        </div>
        <details class="mt-4 rounded-md border border-border bg-surface">
          <summary class="cursor-pointer select-none p-3 text-sm text-muted">📊 Ver detalhes do cálculo</summary>
          <div class="space-y-3 p-3 pt-0">
            ${detalheCard('Na cidade', cidade)}
            ${detalheCard('Na estrada', estrada)}
          </div>
        </details>
        <div id="trip-mount"></div>
        <div id="share-mount"></div>
      </div>
    `;
    resultadoEl.scrollIntoView({ behavior: 'smooth', block: 'start' });

    import('react').then((React) =>
      Promise.all([
        import('react-dom/client'),
        import('./TripCalculator.tsx'),
        import('./ShareButton.tsx'),
      ]).then(([{ createRoot }, Trip, Share]) => {
        const tripMount = document.getElementById('trip-mount');
        const shareMount = document.getElementById('share-mount');
        if (tripMount) {
          createRoot(tripMount).render(
            React.createElement(Trip.default, {
              custoGasolinaKm: cidade.custoGasolinaKm,
              custoEtanolKm: cidade.custoEtanolKm,
              autonomiaGasolina: toNumber($('ag-cidade').value),
              autonomiaEtanol: toNumber($('ae-cidade').value),
              tanque,
            })
          );
        }
        if (shareMount) {
          createRoot(shareMount).render(
            React.createElement(Share.default, {
              vehicleSlug: select.value,
              precoGasolina: precoG,
              precoEtanol: precoE,
            })
          );
        }
      })
    );
  });
</script>
